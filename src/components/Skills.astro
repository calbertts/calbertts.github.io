---
import { skillCategories } from '../data/skills';
---

<section id="skills">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="animate-on-scroll stagger-1 mb-12">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-accent">Capabilities</p>
      <h2 class="mt-3 text-4xl text-text-primary md:text-5xl">Skills &amp; Expertise</h2>
      <div class="mt-4 h-1 w-24 rounded-full bg-gradient-to-r from-accent to-highlight"></div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        skillCategories.map((category, index) => (
          <article
            class={`animate-on-scroll stagger-${(index % 6) + 1} rounded-2xl border border-border bg-bg-card p-6 shadow-lg shadow-black/10 transition duration-300 hover:-translate-y-1 hover:border-accent/50`}
          >
            <div class="h-10 w-10"><img src={category.icon} alt={category.title} class="h-full w-full object-contain" style="mix-blend-mode: screen;" /></div>
            <h3 class="mt-5 text-2xl font-semibold text-text-primary">{category.title}</h3>
            <div class="mt-6 flex flex-wrap gap-3">
              {category.skills?.map((skill) => <span class="rounded-full border border-border px-3 py-1.5 text-sm text-text-secondary transition hover:border-accent hover:text-text-primary">{skill}</span>)}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
