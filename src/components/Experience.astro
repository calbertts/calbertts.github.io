---
import { experience } from '../data/experience';
---

<section id="experience">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="animate-on-scroll stagger-1 mb-12">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-accent">Career Journey</p>
      <h2 class="mt-3 text-4xl text-text-primary md:text-5xl">Experience</h2>
      <div class="mt-4 h-1 w-24 rounded-full bg-gradient-to-r from-accent to-highlight"></div>
    </div>

    <div class="relative mt-12">
      <div class="absolute bottom-0 left-4 top-0 w-px bg-border md:hidden"></div>
      <div class="absolute bottom-0 left-1/2 top-0 hidden w-px -translate-x-1/2 bg-gradient-to-b from-transparent via-accent/80 to-transparent md:block"></div>

      {
        experience.map((item, index) => {
          const isEven = index % 2 === 0;
          const staggerClass = `stagger-${(index % 6) + 1}`;

          return (
            <div class="relative mb-10 grid gap-6 md:grid-cols-[1fr_auto_1fr] md:items-start md:gap-8 md:odd:[&>article]:mr-8 md:even:[&>article]:ml-8">
              {isEven ? (
                <>
                  <article class:list={["animate-on-scroll", staggerClass, "ml-10 rounded-2xl border border-border bg-bg-card p-6 shadow-lg shadow-black/10 md:ml-0 md:col-start-1"]}>
                    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-accent">{item.company}</p>
                    <h3 class="mt-2 text-2xl font-semibold text-text-primary">{item.role}</h3>
                    <p class="mt-2 text-sm text-text-secondary">{item.period} • {item.location}</p>

                    <ul class="mt-5 space-y-3 text-sm leading-7 text-text-secondary">
                      {item.highlights?.map((highlight) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent"></span><span>{highlight}</span></li>)}
                    </ul>

                    <div class="mt-6 flex flex-wrap gap-2">
                      {item.tags?.map((tag) => <span class="rounded-full border border-border bg-bg-dark px-3 py-1 text-xs text-text-secondary">{tag}</span>)}
                    </div>
                  </article>
                  <div class="absolute left-4 top-8 z-10 h-4 w-4 -translate-x-1/2 rounded-full border-4 border-bg-dark bg-accent shadow-[0_0_0_6px_rgba(212,148,58,0.12)] md:static md:left-auto md:top-auto md:translate-x-0 md:col-start-2"></div>
                  <div class="hidden md:block md:col-start-3"></div>
                </>
              ) : (
                <>
                  <div class="hidden md:block md:col-start-1"></div>
                  <div class="absolute left-4 top-8 z-10 h-4 w-4 -translate-x-1/2 rounded-full border-4 border-bg-dark bg-accent shadow-[0_0_0_6px_rgba(212,148,58,0.12)] md:static md:left-auto md:top-auto md:translate-x-0 md:col-start-2"></div>
                  <article class:list={["animate-on-scroll", staggerClass, "ml-10 rounded-2xl border border-border bg-bg-card p-6 shadow-lg shadow-black/10 md:ml-0 md:col-start-3"]}>
                    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-accent">{item.company}</p>
                    <h3 class="mt-2 text-2xl font-semibold text-text-primary">{item.role}</h3>
                    <p class="mt-2 text-sm text-text-secondary">{item.period} • {item.location}</p>

                    <ul class="mt-5 space-y-3 text-sm leading-7 text-text-secondary">
                      {item.highlights?.map((highlight) => <li class="flex gap-3"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent"></span><span>{highlight}</span></li>)}
                    </ul>

                    <div class="mt-6 flex flex-wrap gap-2">
                      {item.tags?.map((tag) => <span class="rounded-full border border-border bg-bg-dark px-3 py-1 text-xs text-text-secondary">{tag}</span>)}
                    </div>
                  </article>
                </>
              )}
            </div>
          );
        })
      }
    </div>
  </div>
</section>
