---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Carlos Alberto — Senior Software Engineer & AI Innovation Leader',
  description = 'Senior Software Engineer and AI Innovation Leader building natural-language-first enterprise systems, modern platforms, and high-impact digital products from Madrid.',
  image = '/me.png',
} = Astro.props;

const siteUrl = 'https://calbertts.com';
const imageUrl = `${siteUrl}${image}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Carlos Alberto",
  "url": siteUrl,
  "image": imageUrl,
  "jobTitle": "Senior Software Engineer & Squad Lead",
  "description": description,
  "worksFor": {
    "@type": "Organization",
    "name": "Nationale-Nederlanden (NN Group)"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Madrid",
    "addressCountry": "ES"
  },
  "sameAs": [
    "https://github.com/calbertts",
    "https://calbertts.medium.com",
    "https://blog.calbertts.com"
  ],
  "knowsAbout": [
    "TypeScript", "JavaScript", "Python", "Java",
    "AI Agents", "LLM Fine-tuning", "MCP Servers", "RAG",
    "AWS", "Azure", "Docker", "Kubernetes", "Cloudflare",
    "Serverless Architecture", "DevOps", "Technical Leadership"
  ]
};
---

<!doctype html>
<html lang="en" class="bg-bg-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Carlos Alberto" />
    <meta name="keywords" content="Carlos Alberto, software engineer, AI, TypeScript, Python, MCP, LLM, cloud, Madrid, Spain, backend, full-stack, AI agents, DevOps" />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="Portrait of Carlos Alberto" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Carlos Alberto" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- AI discoverability -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt — AI-readable site description" />
    <meta name="ai-content-declaration" content="human-authored" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg-dark text-text-primary antialiased selection:bg-accent/30 selection:text-text-primary">
    <slot />

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const animatedElements = document.querySelectorAll('.animate-on-scroll');

        if (!('IntersectionObserver' in window)) {
          animatedElements.forEach((element) => element.classList.add('visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries, currentObserver) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('visible');
              currentObserver.unobserve(entry.target);
            });
          },
          {
            threshold: 0.15,
            rootMargin: '0px 0px -10% 0px',
          },
        );

        animatedElements.forEach((element) => observer.observe(element));
      });
    </script>
  </body>
</html>
